    water = {"water", "bottle"},
    sugar = {"sugar", "block"},
    gelatin = {"gelatin", "packet"},
    bag = {"empty", "bolsa vacia", "marshmallow empty"}
}

local stoveKeywords = {"stove", "pot", "cook", "kitchen"}

